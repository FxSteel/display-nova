{
  "name": "nova-display",
  "version": "0.1.0",
  "private": true,
  "description": "NOVA Display Player — Electron/Vite workspace",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run predev && npm-run-all --parallel dev:renderer dev:main dev:electron",
    "predev": "npm run build:main",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "vite",
    "react",
    "display"
  ],
  "author": "FxSteel",
  "license": "MIT",
  "dependencies": {
    "canvas": "^3.2.1",
    "grandiose": "^0.0.4",
    "koffi": "^2.15.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.34",
    "@types/react-dom": "^18.2.16",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "wait-on": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FxSteel/display-nova.git"
  },
  "engines": {
    "node": ">=18"
  }
}
